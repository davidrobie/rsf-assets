---
// Hero.astro — the "Step Inside" hero section, image + headline + body
interface Props {
  eyebrow?: string;
  heading: string;
  body?: string;
  image?: string;
  imageAlt?: string;
}
const { eyebrow = 'Step Inside', heading, body, image, imageAlt = '' } = Astro.props;
---

<section class="hero section">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">{eyebrow}</p>
        <h2>{heading}</h2>
        {body && <div class="hero-body"><slot>{body}</slot></div>}
        {!body && <div class="hero-body"><slot /></div>}
      </div>
      <figure class="hero-figure">
        {image ? (
          <img src={image} alt={imageAlt} loading="eager" />
        ) : (
          <div class="hero-placeholder" aria-hidden="true">
            <svg viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg">
              <rect width="400" height="300" fill="var(--paper-deep)" />
              <text x="50%" y="50%" text-anchor="middle" dominant-baseline="middle"
                    font-family="Fraunces, serif" font-size="20" fill="var(--muted)">
                Hero image
              </text>
            </svg>
          </div>
        )}
      </figure>
    </div>
  </div>
</section>

<style>
  .hero { padding-block: clamp(2rem, 5vw, 4rem); }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .hero-copy h2 { margin-top: 0.4rem; }
  .hero-body { font-size: var(--step-0); color: var(--ink-soft); }
  .hero-body :global(p) { margin-bottom: 1em; }
  .hero-figure {
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-2);
    background: var(--paper-deep);
  }
  .hero-figure img { width: 100%; height: 100%; object-fit: cover; }
  .hero-placeholder svg { width: 100%; height: auto; display: block; }

  @media (max-width: 800px) {
    .hero-grid { grid-template-columns: 1fr; }
  }
</style>
