---
// ChapterNav.astro — previous / next chapter navigation
interface NavItem {
  href: string;
  label: string;     // chapter number, e.g. "Chapter 2"
  title: string;     // chapter title
}
interface Props {
  prev?: NavItem;
  next?: NavItem;
}
const { prev, next } = Astro.props;
---

<nav class="chapter-nav section-tight" aria-label="Chapter navigation">
  <div class="container">
    <div class="nav-grid">
      {prev ? (
        <a href={prev.href} class="nav-card nav-prev">
          <span class="nav-direction">← {prev.label}</span>
          <span class="nav-title">{prev.title}</span>
        </a>
      ) : <div />}
      {next ? (
        <a href={next.href} class="nav-card nav-next">
          <span class="nav-direction">{next.label} →</span>
          <span class="nav-title">{next.title}</span>
        </a>
      ) : <div />}
    </div>
  </div>
</nav>

<style>
  .chapter-nav { border-top: 1px solid var(--rule); padding-top: 2rem; }
  .nav-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .nav-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    color: var(--ink);
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: var(--radius);
    transition: transform 150ms, box-shadow 150ms, border-color 150ms;
  }
  .nav-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-1);
    border-color: var(--copper);
  }
  .nav-next { text-align: right; }
  .nav-direction {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--copper);
  }
  .nav-title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    line-height: 1.3;
  }
  @media (max-width: 600px) {
    .nav-grid { grid-template-columns: 1fr; }
    .nav-next { text-align: left; }
  }
</style>
