---
// ToolsTemplates.astro — image left, content + downloadable links right
interface ToolLink {
  label: string;
  href: string;
  meta?: string;  // e.g. "PDF · 1.2 MB"
}
interface Props {
  eyebrow?: string;
  heading: string;
  body?: string;
  image?: string;
  imageAlt?: string;
  tools?: ToolLink[];
}
const {
  eyebrow = 'Directed Tools & Templates',
  heading,
  body,
  image,
  imageAlt = '',
  tools = [],
} = Astro.props;
---

<section class="tools section">
  <div class="container">
    <div class="tools-grid">
      <figure class="tools-figure">
        {image ? (
          <img src={image} alt={imageAlt} />
        ) : (
          <div class="tools-placeholder" aria-hidden="true">
            <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
              <rect width="400" height="400" fill="var(--paper-deep)" />
              <text x="50%" y="50%" text-anchor="middle" dominant-baseline="middle"
                    font-family="Fraunces, serif" font-size="22" fill="var(--muted)">
                Tools image
              </text>
            </svg>
          </div>
        )}
      </figure>

      <div class="tools-copy">
        <p class="eyebrow">{eyebrow}</p>
        <h2>{heading}</h2>
        {body && <div class="tools-body" set:html={body} />}
        {!body && <slot />}

        {tools.length > 0 && (
          <ul class="tools-list">
            {tools.map(t => (
              <li>
                <a href={t.href} class="tool-link">
                  <span class="tool-arrow" aria-hidden="true">→</span>
                  <span class="tool-label">{t.label}</span>
                  {t.meta && <span class="tool-meta">{t.meta}</span>}
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .tools-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .tools-figure {
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-2);
    aspect-ratio: 4 / 5;
    background: var(--paper-deep);
  }
  .tools-figure img { width: 100%; height: 100%; object-fit: cover; }
  .tools-placeholder svg { width: 100%; height: 100%; }

  .tools-copy h2 { margin: 0.3rem 0 1rem; }
  .tools-body :global(p) { margin-bottom: 1em; }

  .tools-list {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .tools-list li {
    border-top: 1px solid var(--rule);
  }
  .tools-list li:last-child { border-bottom: 1px solid var(--rule); }

  .tool-link {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.85rem 0;
    text-decoration: none;
    color: var(--ink);
    transition: color 120ms, padding 200ms;
  }
  .tool-link:hover { color: var(--copper-dark); padding-left: 0.4rem; }
  .tool-arrow {
    color: var(--copper);
    font-weight: 600;
    transition: transform 200ms;
  }
  .tool-link:hover .tool-arrow { transform: translateX(2px); }
  .tool-label {
    font-family: var(--font-display);
    font-size: var(--step-1);
    flex: 1;
  }
  .tool-meta {
    font-size: 0.8rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  @media (max-width: 800px) {
    .tools-grid { grid-template-columns: 1fr; }
    .tools-figure { aspect-ratio: 16 / 10; max-height: 22rem; }
  }
</style>
